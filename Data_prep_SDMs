###                   OCCURRENCE RECORDS
###                   
###########################################################
# 1.  Load records for all species
obs.data <- read.csv ("SDMs/Data/Occs.csv")
Spp<-unique(obs.data$species) # get species names
sp_code <- c("Abo","Aau","Aam","Can","Cgl","Hat") #create a short name for each

### 2. Split the data by spp
occs.sp <- lapply(1:6, function(x) {
  print(paste("Processing:", Spp[x]))
  obs.data %>%
    filter(species == Spp[x])
})

names(occs.sp) <- sp_code # name the list elements with the species names

### 3. Apply a spatial thinning (5 km minimum distance among points)
set.seed(48)

occs.thin <- lapply(1:6, function(x) {
  print(paste("Processing:", Spp[x]))
  occs.sp.thin<- spThin::thin(loc.data =occs.sp[[x]], lat.col = "lat", long.col = "lon", spec.col = "species",  thin.par = 5, reps = 10, locs.thinned.list.return = TRUE, write.files = FALSE)
  
  #Choose the first combination
  occs.sp.thin2<-occs.sp.thin[[1]]
  
  print(paste("Choosing one set of thinned data for:", Spp[x]))
  
  print(paste("============================================="))
  
  print(paste("============MOVING TO NEXT SPECIES==========="))
  
  #Standardize column name
  names(occs.sp.thin2) <- c("x", "y")
  
  return(occs.sp.thin2)
})

names(occs.thin) <- sp_code

sapply(occs.thin, nrow) ##check number of records per species after thinning


