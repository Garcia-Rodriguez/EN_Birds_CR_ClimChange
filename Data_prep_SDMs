################################################################################

###                             CALIBRATION AREAS

################################################################################
calib.area_shp_vif <- lapply(1:6, function(x) {
  print(paste("Processing:", sp_code[x]))
  
  #Create buffer
  buffer_shp <- terra::aggregate(buffer(vect(paste0("Spp_shps/", sp_code[x], ".shp")), 
                                        width = 50000))
  
  #Crop clim vars con buffer
  buffer_shp.clim<-crop(mask(WC_region, buffer_shp), buffer_shp)
  
  #Checar colinearidad y reducir vars
  vif.test <- vifstep(buffer_shp.clim, th = 10)
  
  # Exclude highly correlated variables
  calibration.area.vif <- exclude(buffer_shp.clim, vif.test)
  
  return(calibration.area.vif)
})

names(calib.area_shp_vif) <- sp_code

#Check one species
x=4 #(Can)

plot(calib.area_shp_vif[[x]][[x]], main= paste0("Calibration area for: ",sp_code[x]))


##############################################################################
###                        BACKGROUND POINTS                               ###
##############################################################################
bg.points <-  lapply(1:6, function(x){
  print(paste("Processing: ", sp_code[x]))
  
  bg.points <- data.frame(
    spatSample(calib.area_shp_vif[[x]][[1]], 
               size = 5000, 
               xy = TRUE, 
               values = FALSE, 
               na.rm = TRUE)
  )
  names(bg.points) <- c("x", "y")
  
  # Save plot to file
  #png(paste0("BG_plots/", sp_code[x], "_background.png"), width = 800, height = 800) #optional
  plot(calib.area_shp_vif[[x]][[1]], main = paste("BG points for ", sp_code[x]))
  points(bg.points, pch = 20, cex = 1.2)
  #dev.off()
  
  return(bg.points)
})

names(bg.points) <- sp_code
